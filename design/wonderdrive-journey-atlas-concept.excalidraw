      "fontSize": 18,
      "fontFamily": 5,
      "text": "A monument stops behaving like shared memory when its official story\nno longer matches lived experience. Conflict is not just about the object;\nit is about who is allowed to define the public meaning of a place.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A monument stops behaving like shared memory when its official story\nno longer matches lived experience. Conflict is not just about the object;\nit is about who is allowed to define the public meaning of a place.",
      "autoResize": true,
      "lineHeight": 1.25
    },
